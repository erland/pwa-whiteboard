{
  "name": "pwa-whiteboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "npm run typecheck && node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "test": "jest",
    "deploy": "gh-pages -d dist",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck:all": "node node_modules/typescript/bin/tsc -p tsconfig.json && node node_modules/typescript/bin/tsc -p shared/tsconfig.json",
    "typecheck:shared": "node node_modules/typescript/bin/tsc -p shared/tsconfig.json",
    "typecheck:worker": "node node_modules/typescript/bin/tsc -p workers/collab/tsconfig.json",
    "worker:dev": "cd workers/collab && npx wrangler dev",
    "worker:deploy": "cd workers/collab && npx wrangler deploy",
    "verify": "npm test -- --runInBand && npm run typecheck:all && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "gh-pages": "^6.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "vite": "^7.2.6"
  }
}
